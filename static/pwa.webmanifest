{
  "name": "SynapSeq Hub Player",
  "short_name": "Hub Player",
  "description": "Browse and play SynapSeq audio packages from the hub catalog.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait-primary",
